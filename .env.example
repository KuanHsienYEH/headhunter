# ── 必填 ───────────────────────────────────────────────
# 資料庫:Vercel 用 Neon(雲端 Postgres)連線字串;本機用 postgresql://localhost:5432/headhunter
DATABASE_URL=
# NextAuth 加密金鑰:openssl rand -base64 32
AUTH_SECRET=
# 正式站填你的網域,如 https://www.jujianghr.com.tw;本機 http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 檔案上傳(履歷 + 獎狀)── Vercel 必填;本機留空則獎狀存到 public/uploads/
# 履歷一定要 S3;獎狀未設 S3 時 fallback 到本機硬碟(Vercel 無法寫檔,故雲端必填)
S3_BUCKET_NAME=
S3_REGION=ap-northeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Email 通知(履歷/委託送出時)── 選填,未填則不寄信
RESEND_API_KEY=
NOTIFY_EMAIL=

# ── 預設後台帳號 ── 選填;資料庫已有 admin 帳號時可不填
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH_B64=
