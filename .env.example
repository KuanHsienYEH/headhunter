# ── 必填 ───────────────────────────────────────────────
# 資料庫:Vercel 用 Neon(雲端 Postgres)連線字串;本機用 postgresql://localhost:5432/headhunter
DATABASE_URL=
# NextAuth 加密金鑰:openssl rand -base64 32
AUTH_SECRET=
# 正式站填你的網域,如 https://www.jujianghr.com.tw;本機 http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AWS S3 ── 履歷所有環境必填；bucket 維持 private
S3_REGION=us-east-2
S3_BUCKET_NAME=jujiang-077101397709-us-east-2-an
# 本機使用 dev；Vercel Production 使用 prod
S3_PREFIX=dev
S3_ACCESS_KEY_ID=<DEV_ACCESS_KEY>
S3_SECRET_ACCESS_KEY=<DEV_SECRET_KEY>

# ── Email 通知(履歷/委託送出時)── 選填,未填則不寄信
RESEND_API_KEY=
NOTIFY_EMAIL=

# ── 預設後台帳號 ── 選填;資料庫已有 admin 帳號時可不填
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH_B64=
